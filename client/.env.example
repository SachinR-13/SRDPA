# ================= SRPay Frontend Environment Variables =================

# Backend API URL (for production builds)
# In development, Vite proxy handles /api requests automatically
# In production, set this to your Render backend URL
VITE_API_URL=https://srpay-backend.onrender.com/api

# Razorpay Key ID (for payment integration)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ================= Firebase Configuration (for real SMS OTP) =================
# Get these from Firebase Console -> Project Settings -> General -> Your apps -> Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456